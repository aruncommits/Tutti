# Tutti — app-provided AI keys (server-side only; never shipped to the client).
# Copy this file to `apps/web/.env` and paste your OWN keys. `.env` is gitignored.
# You only need the providers you want to use — the router falls back across whatever is set.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Free-tier AI recipes before the quota gate (dev stub; real billing comes later).
AI_FREE_LIMIT=20

# Security (Brief v40): the paid AI endpoint is LOCALHOST-ONLY by default. To test "Ask AI" on another
# device on your LAN (e.g. a phone), set AI_ALLOW_LAN=1. For a shared dev secret, also set AI_DEV_TOKEN
# AND expose the same value to the client as VITE_AI_DEV_TOKEN so the app sends the x-dev-token header.
AI_ALLOW_LAN=
AI_DEV_TOKEN=
# VITE_AI_DEV_TOKEN=   # client copy of AI_DEV_TOKEN (only if using LAN + token); reaches the bundle

# --- Recipe library (Supabase Postgres) ---------------------------------------------------------
# Connection string from Supabase (Settings → Database). Percent-encode special chars in the password
# (e.g. "@" → "%40"). Server-side only; never shipped to the client.
SUPABASE_DB_URL=
# TLS: set ONE of the following. Preferred — pin the Supabase CA cert path for verified TLS:
SUPABASE_CA_CERT=
# …or, for LOCAL DEV ONLY, explicitly allow encrypted-but-unverified TLS (the pooler cert isn't in the
# system trust store). Leave unset in production — the DB client FAILS CLOSED without one of these.
ALLOW_INSECURE_TLS=
